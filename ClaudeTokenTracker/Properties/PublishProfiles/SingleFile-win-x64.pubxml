<?xml version="1.0" encoding="utf-8"?>
<!--
  One-file release profile: produces a single, self-contained ClaudeTokenTracker.exe
  that runs on any Windows 10 (1803+) / 11 x64 machine WITHOUT the .NET runtime installed.

  Publish from the CLI with:   .\publish.ps1
  ...or from Visual Studio:     right-click project -> Publish -> SingleFile-win-x64

  Notes:
   - SelfContained bundles the .NET 8 runtime, so end users need no install.
   - IncludeNativeLibrariesForSelfExtract folds the native runtime DLLs into the exe
     (otherwise they'd sit loose beside it), giving a true single file.
   - EnableCompressionInSingleFile keeps the bundled-runtime exe down to a sane size.
   - DebugType=embedded means no loose .pdb in the output: the artifact is one .exe.
   - Trimming is intentionally NOT enabled: WinForms relies on reflection and trimming
     can silently break it.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- ReadyToRun is off: pre-JIT images can fail on some CPUs; self-contained + single-file is enough. -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <DebugType>embedded</DebugType>
  </PropertyGroup>
</Project>
