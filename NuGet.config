<?xml version="1.0" encoding="utf-8"?>
<!--
  The app itself uses ZERO NuGet packages, so the default (lean, framework-dependent)
  build needs no package source. This source exists solely so the *self-contained
  single-file release* (publish.ps1) can download the .NET 8 runtime packs it bundles
  into the standalone .exe. <clear /> avoids inheriting any broken machine-wide sources.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
